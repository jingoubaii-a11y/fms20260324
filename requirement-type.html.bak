<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>需求类型 - 财务中台</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#003eb3',
                        secondary: '#e6f0ff',
                        accent: '#ff6b6b',
                        neutral: '#f5f7fa',
                    },
                    borderRadius: {
                        'sm': '4px',
                        'md': '8px',
                        'lg': '12px',
                        'xl': '16px',
                    },
                },
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            height: 100vh;
            overflow: hidden;
        }
        
        .sidebar {
            transition: width 0.3s ease-in-out;
            overflow-y: auto;
            height: 100vh;
        }
        
        .sidebar.collapsed {
            width: 64px;
        }
        
        .sidebar.collapsed .sidebar-text {
            display: none;
        }
        
        .sidebar.collapsed .sidebar-icon {
            margin: 0 auto;
        }
        
        .sidebar-item {
            transition: all 0.2s ease-in-out;
            font-size: 0.875rem;
        }
        
        .sidebar-item:hover {
            background-color: rgba(255, 255, 255, 0.1);
        }
        
        .sidebar-item.active {
            background-color: rgba(255, 255, 255, 0.2);
            color: white;
            font-weight: 500;
        }
        
        .gradient-bg {
            background: linear-gradient(135deg, #003eb3 0%, #0056c7 100%);
        }
        
        .menu-header h2 {
            font-size: 0.875rem;
            color: rgba(255, 255, 255, 0.7);
        }
        
        .drawer {
            transition: transform 0.3s ease-in-out;
            transform: translateX(100%);
        }
        
        .drawer.open {
            transform: translateX(0);
        }
        
        .drawer-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 15;
            display: none;
        }
        
        .drawer-overlay.open {
            display: block;
        }
        
        .switch {
            position: relative;
            display: inline-block;
            width: 44px;
            height: 24px;
        }
        
        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }
        
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: .4s;
            border-radius: 24px;
        }
        
        .slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }
        
        input:checked + .slider {
            background-color: #003eb3;
        }
        
        input:checked + .slider:before {
            transform: translateX(20px);
        }
    </style>
</head>
<body class="bg-neutral">
    <!-- 主容器 -->
    <div class="flex h-screen">
        <!-- 侧边栏 -->
        <aside id="sidebar" class="sidebar gradient-bg text-white shadow-sm fixed left-0 top-0 bottom-0 w-64 overflow-y-auto z-10">
            <div class="p-4 flex items-center justify-between border-b border-white/20">
                <h1 class="text-xl font-semibold">财务中台</h1>
                <button id="toggle-sidebar" class="p-2 rounded-md hover:bg-white/10">
                    <i data-lucide="menu"></i>
                </button>
            </div>
            <nav class="py-4">
                <!-- 仪表盘 -->
                <a href="index.html" class="sidebar-item flex items-center px-4 py-3 text-white/90 hover:text-white rounded-md">
                    <i data-lucide="home" class="sidebar-icon w-5 h-5 mr-3"></i>
                    <span class="sidebar-text">仪表盘</span>
                </a>
                
                <!-- 基础资料 -->
                <div class="mt-4">
                    <div class="menu-header flex items-center justify-between px-4 py-2 cursor-pointer" data-menu="basic-data">
                        <h2 class="text-xs font-semibold uppercase tracking-wider">基础资料</h2>
                        <i data-lucide="chevron-down" class="menu-icon w-4 h-4 text-white/70 transition-transform"></i>
                    </div>
                    <div class="menu-content px-2 py-2" id="basic-data-content">
                        <a href="financial-entity.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="building" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">财务主体</span>
                        </a>
                        <a href="merchant.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="users" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">客商</span>
                        </a>
                        <a href="project.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="clipboard-list" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">项目</span>
                        </a>
                        <a href="material.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="package" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">物料</span>
                        </a>
                        <a href="cost-ratio.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="pie-chart" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">成本比例配置</span>
                        </a>
                    </div>
                </div>
                
                <!-- 公共资料 -->
                <div class="mt-4">
                    <div class="menu-header flex items-center justify-between px-4 py-2 cursor-pointer" data-menu="public-data">
                        <h2 class="text-xs font-semibold uppercase tracking-wider">公共资料</h2>
                        <i data-lucide="chevron-down" class="menu-icon w-4 h-4 text-white/70 transition-transform"></i>
                    </div>
                    <div class="menu-content px-2 py-2" id="public-data-content">
                        <a href="currency.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="dollar-sign" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">币别</span>
                        </a>
                        <a href="accounting-calendar.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="calendar" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">会计日历</span>
                        </a>
                        <a href="document-type.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="file-text" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">单据类型</span>
                        </a>
                        <a href="tax-rate.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="percent" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">税率</span>
                        </a>
                        <a href="invoice-type.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="file-invoice" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">发票类型</span>
                        </a>
                        <a href="unit.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="ruler" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">计量单位</span>
                        </a>
                        <a href="requirement-type.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md active">
                            <i data-lucide="list-checks" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">需求类型</span>
                        </a>
                        <a href="source-system.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="cloud" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">来源系统</span>
                        </a>
                    </div>
                </div>
                
                <!-- 项目管理 -->
                <div class="mt-4">
                    <div class="menu-header flex items-center justify-between px-4 py-2 cursor-pointer" data-menu="project-management">
                        <h2 class="text-xs font-semibold uppercase tracking-wider">项目管理</h2>
                        <i data-lucide="chevron-down" class="menu-icon w-4 h-4 text-white/70 transition-transform"></i>
                    </div>
                    <div class="menu-content px-2 py-2" id="project-management-content">
                        <a href="project-overview.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="bar-chart-3" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">项目概览</span>
                        </a>
                        <a href="process-acceptance.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="check-circle" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">工序验收管理</span>
                        </a>
                        <a href="accounting-method.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="calculator" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">核算方法管理</span>
                        </a>
                        <a href="project-accounting.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="book" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">项目核算</span>
                        </a>
                    </div>
                </div>
                
                <!-- 应收管理 -->
                <div class="mt-4">
                    <div class="menu-header flex items-center justify-between px-4 py-2 cursor-pointer" data-menu="receivable-management">
                        <h2 class="text-xs font-semibold uppercase tracking-wider">应收管理</h2>
                        <i data-lucide="chevron-down" class="menu-icon w-4 h-4 text-white/70 transition-transform"></i>
                    </div>
                    <div class="menu-content px-2 py-2" id="receivable-management-content">
                        <a href="receivable.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="credit-card" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">应收单</span>
                        </a>
                        <a href="receipt.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="cash" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">收款单</span>
                        </a>
                    </div>
                </div>
            </nav>
        </aside>

        <!-- 主内容区 -->
        <main class="flex-1 ml-64 p-6 transition-all duration-300 overflow-y-auto" id="main-content">
            <div class="bg-white rounded-lg shadow-sm p-6">
                <div class="border-b border-gray-200 pb-4 mb-6">
                    <h1 class="text-xl font-semibold text-gray-800">需求类型管理</h1>
                </div>
                <!-- 筛选条件和按钮栏 -->
                <div class="flex items-center justify-between mb-6 flex-nowrap">
                    <div class="flex items-center space-x-2 flex-1">
                        <select id="filter-field-requirement-type" class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                            <option value="code">需求类型编码</option>
                            <option value="name">需求类型名称</option>
                            <option value="status">状态</option>
                        </select>
                        <input type="text" id="filter-value-requirement-type" placeholder="按需求类型编码搜索" class="w-64 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        <button class="px-3 py-2 bg-gray-100 border border-gray-300 rounded-md hover:bg-gray-200 transition-colors">
                            <i data-lucide="search" class="w-4 h-4"></i>
                        </button>
                        <button class="px-3 py-2 bg-gray-100 border border-gray-300 rounded-md hover:bg-gray-200 transition-colors">
                            <i data-lucide="refresh-ccw" class="w-4 h-4"></i>
                        </button>
                        <button id="advanced-filter-btn-requirement-type" class="px-3 py-2 text-primary hover:bg-secondary rounded-md transition-colors flex items-center">
                            高级筛选
                            <i data-lucide="chevron-down" class="w-4 h-4 ml-1"></i>
                        </button>
                    </div>
                    <button id="add-requirement-type" class="px-4 py-2 bg-primary text-white rounded-md hover:bg-blue-700 transition-colors flex items-center">
                        <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
                        新增
                    </button>
                </div>
                
                <!-- 高级筛选展开区域 -->
                <div id="advanced-filter-requirement-type" class="hidden bg-gray-50 p-4 rounded-md border border-gray-200 mb-6">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">需求类型编码</label>
                            <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">需求类型名称</label>
                            <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">状态</label>
                            <select class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                <option value="">全部</option>
                                <option value="enabled">启用</option>
                                <option value="disabled">停用</option>
                            </select>
                        </div>
                    </div>
                    <div class="mt-4 flex justify-end space-x-2">
                        <button class="px-4 py-2 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors">
                            重置
                        </button>
                        <button class="px-4 py-2 bg-primary text-white rounded-md hover:bg-blue-700 transition-colors">
                            查询
                        </button>
                    </div>
                </div>
                
                <!-- 列表 -->
                <div class="overflow-x-auto">
                    <table class="min-w-full bg-white border border-gray-200 rounded-lg">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">需求类型编码</th>
                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">需求类型名称</th>
                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">说明</th>
                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">项目类型</th>
                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">关联订单需求标签</th>
                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">状态</th>
                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">操作</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            <tr>
                                <td class="px-4 py-2 text-sm text-gray-700">REQ001</td>
                                <td class="px-4 py-2 text-sm text-gray-700">整装需求</td>
                                <td class="px-4 py-2 text-sm text-gray-700">整体装修需求</td>
                                <td class="px-4 py-2 text-sm text-gray-700">整装</td>
                                <td class="px-4 py-2 text-sm text-gray-700">全屋整装,新房装修</td>
                                <td class="px-4 py-2">
                                    <label class="switch">
                                        <input type="checkbox" checked>
                                        <span class="slider"></span>
                                    </label>
                                </td>
                                <td class="px-4 py-2 text-sm">
                                    <div class="flex space-x-2">
                                        <button class="text-primary hover:text-blue-700 view-requirement-type">查看</button>
                                        <button class="text-primary hover:text-blue-700 edit-requirement-type">编辑</button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm text-gray-700">REQ002</td>
                                <td class="px-4 py-2 text-sm text-gray-700">软装需求</td>
                                <td class="px-4 py-2 text-sm text-gray-700">软装配饰需求</td>
                                <td class="px-4 py-2 text-sm text-gray-700">软装</td>
                                <td class="px-4 py-2 text-sm text-gray-700">软装设计,家具配置</td>
                                <td class="px-4 py-2">
                                    <label class="switch">
                                        <input type="checkbox" checked>
                                        <span class="slider"></span>
                                    </label>
                                </td>
                                <td class="px-4 py-2 text-sm">
                                    <div class="flex space-x-2">
                                        <button class="text-primary hover:text-blue-700 view-requirement-type">查看</button>
                                        <button class="text-primary hover:text-blue-700 edit-requirement-type">编辑</button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm text-gray-700">REQ003</td>
                                <td class="px-4 py-2 text-sm text-gray-700">设计需求</td>
                                <td class="px-4 py-2 text-sm text-gray-700">装修设计需求</td>
                                <td class="px-4 py-2 text-sm text-gray-700">设计费</td>
                                <td class="px-4 py-2 text-sm text-gray-700">设计咨询,方案设计</td>
                                <td class="px-4 py-2">
                                    <label class="switch">
                                        <input type="checkbox" checked>
                                        <span class="slider"></span>
                                    </label>
                                </td>
                                <td class="px-4 py-2 text-sm">
                                    <div class="flex space-x-2">
                                        <button class="text-primary hover:text-blue-700 view-requirement-type">查看</button>
                                        <button class="text-primary hover:text-blue-700 edit-requirement-type">编辑</button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm text-gray-700">REQ004</td>
                                <td class="px-4 py-2 text-sm text-gray-700">局部改造</td>
                                <td class="px-4 py-2 text-sm text-gray-700">局部空间改造需求</td>
                                <td class="px-4 py-2 text-sm text-gray-700">整装</td>
                                <td class="px-4 py-2 text-sm text-gray-700">厨房改造,卫生间改造</td>
                                <td class="px-4 py-2">
                                    <label class="switch">
                                        <input type="checkbox">
                                        <span class="slider"></span>
                                    </label>
                                </td>
                                <td class="px-4 py-2 text-sm">
                                    <div class="flex space-x-2">
                                        <button class="text-primary hover:text-blue-700 view-requirement-type">查看</button>
                                        <button class="text-primary hover:text-blue-700 edit-requirement-type">编辑</button>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                
                <!-- 分页 -->
                <div class="mt-6 flex items-center justify-between">
                    <div class="text-sm text-gray-500">
                        显示 1-4 条，共 4 条
                    </div>
                    <div class="flex space-x-1">
                        <button class="px-3 py-1 border border-gray-300 rounded-md text-sm text-gray-500 hover:bg-gray-50 disabled:opacity-50" disabled>
                            上一页
                        </button>
                        <button class="px-3 py-1 border border-primary bg-primary text-white rounded-md text-sm">1</button>
                        <button class="px-3 py-1 border border-gray-300 rounded-md text-sm text-gray-500 hover:bg-gray-50 disabled:opacity-50" disabled>
                            下一页
                        </button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- 抽屉遮罩层 -->
    <div class="drawer-overlay" id="drawer-overlay"></div>

    <!-- 新增/编辑需求类型抽屉 -->
    <div id="requirement-type-drawer" class="drawer fixed top-0 right-0 h-full w-96 bg-white shadow-lg z-20 p-6 overflow-y-auto">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-semibold text-gray-800" id="drawer-title">新增需求类型</h3>
            <button id="close-drawer" class="p-2 rounded-md hover:bg-gray-100">
                <i data-lucide="x"></i>
            </button>
        </div>
        <form id="requirement-type-form">
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">需求类型编码 <span class="text-red-500">*</span></label>
                    <input type="text" id="requirement-type-code" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">需求类型名称 <span class="text-red-500">*</span></label>
                    <input type="text" id="requirement-type-name" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" required>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">说明</label>
                    <textarea id="requirement-type-desc" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" rows="3"></textarea>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">项目类型 <span class="text-red-500">*</span></label>
                    <select id="project-type" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" required>
                        <option value="">请选择</option>
                        <option value="整装">整装</option>
                        <option value="软装">软装</option>
                        <option value="设计费">设计费</option>
                    </select>
                </div>
                <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">关联订单需求标签</label>
                        <div class="relative">
                            <div id="requirement-tags-container" class="flex flex-wrap gap-2 p-2 border border-gray-300 rounded-md min-h-[40px] focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                <!-- 标签将在这里动态生成 -->
                            </div>
                            <div id="requirement-tags-dropdown" class="hidden absolute z-10 top-full left-0 right-0 bg-white border border-gray-300 rounded-md shadow-lg max-h-60 overflow-y-auto">
                                <div class="p-2">
                                    <div class="flex items-center mb-2">
                                        <input type="text" id="requirement-tags-search" placeholder="搜索需求标签" class="w-full px-2 py-1 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                    </div>
                                    <div class="space-y-1">
                                        <div class="flex items-center p-2 hover:bg-gray-50 cursor-pointer" data-value="全屋整装">
                                            <input type="checkbox" class="mr-2" id="tag-全屋整装">
                                            <label for="tag-全屋整装">全屋整装</label>
                                        </div>
                                        <div class="flex items-center p-2 hover:bg-gray-50 cursor-pointer" data-value="新房装修">
                                            <input type="checkbox" class="mr-2" id="tag-新房装修">
                                            <label for="tag-新房装修">新房装修</label>
                                        </div>
                                        <div class="flex items-center p-2 hover:bg-gray-50 cursor-pointer" data-value="软装设计">
                                            <input type="checkbox" class="mr-2" id="tag-软装设计">
                                            <label for="tag-软装设计">软装设计</label>
                                        </div>
                                        <div class="flex items-center p-2 hover:bg-gray-50 cursor-pointer" data-value="家具配置">
                                            <input type="checkbox" class="mr-2" id="tag-家具配置">
                                            <label for="tag-家具配置">家具配置</label>
                                        </div>
                                        <div class="flex items-center p-2 hover:bg-gray-50 cursor-pointer" data-value="设计咨询">
                                            <input type="checkbox" class="mr-2" id="tag-设计咨询">
                                            <label for="tag-设计咨询">设计咨询</label>
                                        </div>
                                        <div class="flex items-center p-2 hover:bg-gray-50 cursor-pointer" data-value="方案设计">
                                            <input type="checkbox" class="mr-2" id="tag-方案设计">
                                            <label for="tag-方案设计">方案设计</label>
                                        </div>
                                        <div class="flex items-center p-2 hover:bg-gray-50 cursor-pointer" data-value="厨房改造">
                                            <input type="checkbox" class="mr-2" id="tag-厨房改造">
                                            <label for="tag-厨房改造">厨房改造</label>
                                        </div>
                                        <div class="flex items-center p-2 hover:bg-gray-50 cursor-pointer" data-value="卫生间改造">
                                            <input type="checkbox" class="mr-2" id="tag-卫生间改造">
                                            <label for="tag-卫生间改造">卫生间改造</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <input type="hidden" id="selected-tags" name="selected-tags">
                    </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">状态</label>
                    <div class="flex items-center">
                        <label class="switch">
                            <input type="checkbox" id="requirement-type-status" checked>
                            <span class="slider"></span>
                        </label>
                        <span class="ml-2 text-sm text-gray-700" id="status-text">启用</span>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">创建人</label>
                        <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50" disabled>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">创建时间</label>
                        <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50" disabled>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">修改人</label>
                        <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50" disabled>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">修改时间</label>
                        <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50" disabled>
                    </div>
                </div>
            </div>
            <div class="mt-6 flex space-x-3">
                <button type="button" id="cancel-btn" class="flex-1 px-4 py-2 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors">
                    关闭
                </button>
                <button type="submit" id="save-btn" class="flex-1 px-4 py-2 bg-primary text-white rounded-md hover:bg-blue-700 transition-colors">
                    保存
                </button>
            </div>
        </form>
    </div>
    
    <!-- 查看需求类型抽屉 -->
    <div id="view-drawer" class="drawer fixed top-0 right-0 h-full w-96 bg-white shadow-lg z-20 p-6 overflow-y-auto">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-semibold text-gray-800">查看需求类型</h3>
            <button id="close-view-drawer" class="p-2 rounded-md hover:bg-gray-100">
                <i data-lucide="x"></i>
            </button>
        </div>
        
        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">需求类型编码</label>
                <div class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50">REQ001</div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">需求类型名称</label>
                <div class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50">整装需求</div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">说明</label>
                <div class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50">整体装修需求</div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">项目类型</label>
                <div class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50">整装</div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">关联订单需求标签</label>
                <div class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50">全屋整装,新房装修</div>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">状态</label>
                <div class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50">启用</div>
            </div>
        </div>
        
        <div class="mt-6">
            <button id="close-view-btn" class="w-full px-4 py-2 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors">
                关闭
            </button>
        </div>
    </div>
    
    <script>
        // 初始化Lucide图标
        lucide.createIcons();
        
        // 侧边栏折叠/展开功能
        const toggleSidebar = document.getElementById('toggle-sidebar');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('main-content');
        
        toggleSidebar.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
            if (sidebar.classList.contains('collapsed')) {
                mainContent.classList.remove('ml-64');
                mainContent.classList.add('ml-16');
            } else {
                mainContent.classList.remove('ml-16');
                mainContent.classList.add('ml-64');
            }
        });
        
        // 菜单展开/收拢功能
        const menuHeaders = document.querySelectorAll('.menu-header');
        
        menuHeaders.forEach(header => {
            header.addEventListener('click', () => {
                const menuName = header.getAttribute('data-menu');
                const content = document.getElementById(`${menuName}-content`);
                const icon = header.querySelector('.menu-icon');
                
                // 切换内容显示/隐藏
                content.classList.toggle('hidden');
                
                // 切换图标旋转
                if (content.classList.contains('hidden')) {
                    icon.style.transform = 'rotate(0deg)';
                } else {
                    icon.style.transform = 'rotate(180deg)';
                }
            });
        });
        
        // 搜索字段切换功能
        const searchField = document.getElementById('filter-field-requirement-type');
        const searchInput = document.getElementById('filter-value-requirement-type');
        
        if (searchField && searchInput) {
            searchField.addEventListener('change', function() {
                const field = this.value;
                let placeholder = '';
                
                switch(field) {
                    case 'code':
                        placeholder = '按需求类型编码搜索';
                        break;
                    case 'name':
                        placeholder = '按需求类型名称搜索';
                        break;
                    case 'status':
                        placeholder = '按状态搜索';
                        break;
                    default:
                        placeholder = '请输入搜索内容';
                }
                
                searchInput.placeholder = placeholder;
            });
        }
        
        // 高级筛选展开/收起功能
        const advancedFilterBtnRequirementType = document.getElementById('advanced-filter-btn-requirement-type');
        const advancedFilterRequirementType = document.getElementById('advanced-filter-requirement-type');
        
        if (advancedFilterBtnRequirementType && advancedFilterRequirementType) {
            advancedFilterBtnRequirementType.addEventListener('click', function() {
                advancedFilterRequirementType.classList.toggle('hidden');
                
                // 切换箭头图标
                const icon = this.querySelector('i');
                if (advancedFilterRequirementType.classList.contains('hidden')) {
                    icon.setAttribute('data-lucide', 'chevron-down');
                } else {
                    icon.setAttribute('data-lucide', 'chevron-up');
                }
                
                // 重新渲染图标
                lucide.createIcons();
            });
        }
        
        // 高亮当前页面的导航项
        const currentPath = window.location.pathname;
        const sidebarItems = document.querySelectorAll('.sidebar-item');
        
        sidebarItems.forEach(item => {
            const href = item.getAttribute('href');
            if (currentPath.includes(href)) {
                item.classList.add('active');
                
                // 展开包含当前页面的菜单
                const menuContent = item.closest('.menu-content');
                if (menuContent) {
                    menuContent.classList.remove('hidden');
                    const menuHeader = menuContent.previousElementSibling;
                    if (menuHeader) {
                        const icon = menuHeader.querySelector('.menu-icon');
                        if (icon) {
                            icon.style.transform = 'rotate(180deg)';
                        }
                    }
                }
            }
        });
        
        // 抽屉遮罩层
        const drawerOverlay = document.getElementById('drawer-overlay');
        
        function openDrawer(drawer) {
            drawer.classList.add('open');
            drawerOverlay.classList.add('open');
        }
        
        function closeDrawer(drawer) {
            drawer.classList.remove('open');
            drawerOverlay.classList.remove('open');
        }
        
        // 点击遮罩层关闭所有抽屉
        drawerOverlay.addEventListener('click', () => {
            document.querySelectorAll('.drawer').forEach(drawer => {
                drawer.classList.remove('open');
            });
            drawerOverlay.classList.remove('open');
        });
        
        // 需求类型抽屉功能
        const addBtn = document.getElementById('add-requirement-type');
        const requirementTypeDrawer = document.getElementById('requirement-type-drawer');
        const closeDrawerBtn = document.getElementById('close-drawer');
        const cancelBtn = document.getElementById('cancel-btn');
        const saveBtn = document.getElementById('save-btn');
        const drawerTitle = document.getElementById('drawer-title');
        const statusToggle = document.getElementById('requirement-type-status');
        const statusText = document.getElementById('status-text');
        
        addBtn.addEventListener('click', () => {
            drawerTitle.textContent = '新增需求类型';
            document.getElementById('requirement-type-form').reset();
            document.getElementById('requirement-type-status').checked = true;
            statusText.textContent = '启用';
            openDrawer(requirementTypeDrawer);
        });
        
        // 编辑按钮点击事件
        document.querySelectorAll('.edit-requirement-type').forEach(btn => {
            btn.addEventListener('click', function() {
                drawerTitle.textContent = '编辑需求类型';
                // 填充表单数据（模拟）
                document.getElementById('requirement-type-code').value = 'REQ001';
                document.getElementById('requirement-type-name').value = '整装需求';
                document.getElementById('requirement-type-desc').value = '整体装修需求';
                document.getElementById('project-type').value = '整装';
                // 清空现有标签
                requirementTagsContainer.innerHTML = '';
                // 模拟选中多个标签
                addRequirementTag('全屋整装', '全屋整装');
                addRequirementTag('新房装修', '新房装修');
                // 更新隐藏输入值
                updateSelectedTags();
                document.getElementById('requirement-type-status').checked = true;
                statusText.textContent = '启用';
                openDrawer(requirementTypeDrawer);
            });
        });
        
        // 查看按钮点击事件
        const viewDrawer = document.getElementById('view-drawer');
        const closeViewDrawer = document.getElementById('close-view-drawer');
        const closeViewBtn = document.getElementById('close-view-btn');
        
        document.querySelectorAll('.view-requirement-type').forEach(btn => {
            btn.addEventListener('click', function() {
                openDrawer(viewDrawer);
            });
        });
        
        closeDrawerBtn.addEventListener('click', () => {
            closeDrawer(requirementTypeDrawer);
        });
        
        cancelBtn.addEventListener('click', () => {
            closeDrawer(requirementTypeDrawer);
        });
        
        saveBtn.addEventListener('click', () => {
            alert('保存成功');
            closeDrawer(requirementTypeDrawer);
        });
        
        closeViewDrawer.addEventListener('click', () => {
            closeDrawer(viewDrawer);
        });
        
        closeViewBtn.addEventListener('click', () => {
            closeDrawer(viewDrawer);
        });
        
        // 状态切换文本更新
        statusToggle.addEventListener('change', function() {
            statusText.textContent = this.checked ? '启用' : '停用';
        });
        
        // 关联订单需求标签选择功能
        const requirementTagsContainer = document.getElementById('requirement-tags-container');
        const requirementTagsDropdown = document.getElementById('requirement-tags-dropdown');
        const requirementTagsSearch = document.getElementById('requirement-tags-search');
        const selectedTagsInput = document.getElementById('selected-tags');
        const requirementTagItems = document.querySelectorAll('#requirement-tags-dropdown [data-value]');
        
        // 打开/关闭下拉框
        requirementTagsContainer.addEventListener('click', () => {
            requirementTagsDropdown.classList.toggle('hidden');
        });
        
        // 点击其他地方关闭下拉框
        document.addEventListener('click', (e) => {
            if (!requirementTagsContainer.contains(e.target) && !requirementTagsDropdown.contains(e.target)) {
                requirementTagsDropdown.classList.add('hidden');
            }
        });
        
        // 搜索功能
        requirementTagsSearch.addEventListener('input', () => {
            const searchTerm = requirementTagsSearch.value.toLowerCase();
            requirementTagItems.forEach(item => {
                const label = item.querySelector('label').textContent.toLowerCase();
                if (label.includes(searchTerm)) {
                    item.style.display = 'flex';
                } else {
                    item.style.display = 'none';
                }
            });
        });
        
        // 处理需求标签选择
        requirementTagItems.forEach(item => {
            const checkbox = item.querySelector('input[type="checkbox"]');
            const label = item.querySelector('label').textContent;
            const value = item.getAttribute('data-value');
            
            checkbox.addEventListener('change', () => {
                if (checkbox.checked) {
                    // 创建标签
                    const tag = document.createElement('div');
                    tag.className = 'flex items-center bg-primary text-white px-2 py-1 rounded-md text-sm';
                    tag.setAttribute('data-value', value);
                    tag.innerHTML = `
                        <span>${label}</span>
                        <button type="button" class="ml-2 text-white hover:text-gray-200">
                            <i data-lucide="x" class="w-3 h-3"></i>
                        </button>
                    `;
                    requirementTagsContainer.appendChild(tag);
                    
                    // 添加标签删除功能
                    const closeBtn = tag.querySelector('button');
                    closeBtn.addEventListener('click', (e) => {
                        e.stopPropagation();
                        tag.remove();
                        checkbox.checked = false;
                        updateSelectedTags();
                    });
                } else {
                    // 移除标签
                    const existingTag = requirementTagsContainer.querySelector(`[data-value="${value}"]`);
                    if (existingTag) {
                        existingTag.remove();
                    }
                }
                
                // 更新隐藏输入值
                updateSelectedTags();
            });
        });
        
        // 更新选中的需求标签到隐藏输入
        function updateSelectedTags() {
            const selectedTags = requirementTagsContainer.querySelectorAll('[data-value]');
            const selectedValues = Array.from(selectedTags).map(tag => tag.getAttribute('data-value'));
            selectedTagsInput.value = selectedValues.join(',');
        }
        
        // 添加需求标签
        function addRequirementTag(value, label) {
            // 创建标签
            const tag = document.createElement('div');
            tag.className = 'flex items-center bg-primary text-white px-2 py-1 rounded-md text-sm';
            tag.setAttribute('data-value', value);
            tag.innerHTML = `
                <span>${label}</span>
                <button type="button" class="ml-2 text-white hover:text-gray-200">
                    <i data-lucide="x" class="w-3 h-3"></i>
                </button>
            `;
            requirementTagsContainer.appendChild(tag);
            
            // 选中对应的复选框
            const checkbox = document.getElementById(`tag-${value}`);
            if (checkbox) {
                checkbox.checked = true;
            }
            
            // 添加标签删除功能
            const closeBtn = tag.querySelector('button');
            closeBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                tag.remove();
                if (checkbox) {
                    checkbox.checked = false;
                }
                updateSelectedTags();
            });
        }
    </script>
</body>
</html>