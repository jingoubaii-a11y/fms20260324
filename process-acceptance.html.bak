<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>工序验收管理 - 财务中台</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#003eb3',
                        secondary: '#e6f0ff',
                        accent: '#ff6b6b',
                        neutral: '#f5f7fa',
                    },
                    borderRadius: {
                        'sm': '4px',
                        'md': '8px',
                        'lg': '12px',
                        'xl': '16px',
                    },
                },
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
        }
        
        .sidebar {
            transition: width 0.3s ease-in-out;
            overflow-y: auto;
            height: 100%;
        }
        
        .sidebar.collapsed {
            width: 64px;
        }
        
        .sidebar.collapsed .sidebar-text {
            display: none;
        }
        
        .sidebar.collapsed .sidebar-icon {
            margin: 0 auto;
        }
        
        .sidebar-item {
            transition: all 0.2s ease-in-out;
            font-size: 0.875rem;
        }
        
        .sidebar-item:hover {
            background-color: rgba(255, 255, 255, 0.1);
        }
        
        .sidebar-item.active {
            background-color: rgba(255, 255, 255, 0.2);
            color: white;
            font-weight: 500;
        }
        
        .gradient-bg {
            background: linear-gradient(135deg, #003eb3 0%, #0056c7 100%);
        }
        
        .menu-header h2 {
            font-size: 0.875rem;
            color: rgba(255, 255, 255, 0.7);
        }
        
        .drawer-shadow {
            box-shadow: -2px 0 10px rgba(0, 0, 0, 0.1);
        }
    </style>
</head>
<body class="bg-neutral">

    <!-- 主容器 -->
    <div class="flex h-screen">
        <!-- 侧边栏 -->
        <aside id="sidebar" class="sidebar gradient-bg text-white shadow-sm fixed left-0 top-0 bottom-0 w-64 overflow-y-auto z-10">
            <div class="p-4 flex items-center justify-between border-b border-white/20">
                <h1 class="text-xl font-semibold text-white">财务中台</h1>
                <button id="toggle-sidebar" class="p-2 rounded-md hover:bg-white/10 text-white">
                    <i data-lucide="menu"></i>
                </button>
            </div>
            <nav class="py-4">
                <!-- 仪表盘 -->
                <a href="index.html" class="sidebar-item flex items-center px-4 py-3 text-white/90 hover:text-white rounded-md">
                    <i data-lucide="home" class="sidebar-icon w-5 h-5 mr-3"></i>
                    <span class="sidebar-text">仪表盘</span>
                </a>
                
                <!-- 基础资料 -->
                <div class="mt-4">
                    <div class="menu-header flex items-center justify-between px-4 py-2 cursor-pointer" data-menu="basic-data">
                        <h2 class="text-xs font-semibold uppercase tracking-wider">基础资料</h2>
                        <i data-lucide="chevron-down" class="menu-icon w-4 h-4 text-white/70 transition-transform"></i>
                    </div>
                    <div class="menu-content px-2 py-2" id="basic-data-content">
                        <a href="financial-entity.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="building" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">财务主体</span>
                        </a>
                        <a href="merchant.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="users" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">客商</span>
                        </a>
                        <a href="project.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="clipboard-list" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">项目</span>
                        </a>
                        <a href="material.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="package" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">物料</span>
                        </a>
                        <a href="cost-ratio.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="pie-chart" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">成本比例配置</span>
                        </a>
                    </div>
                </div>
                
                <!-- 公共资料 -->
                <div class="mt-4">
                    <div class="menu-header flex items-center justify-between px-4 py-2 cursor-pointer" data-menu="public-data">
                        <h2 class="text-xs font-semibold uppercase tracking-wider">公共资料</h2>
                        <i data-lucide="chevron-down" class="menu-icon w-4 h-4 text-white/70 transition-transform"></i>
                    </div>
                    <div class="menu-content px-2 py-2" id="public-data-content">
                        <a href="currency.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="dollar-sign" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">币别</span>
                        </a>
                        <a href="accounting-calendar.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="calendar" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">会计日历</span>
                        </a>
                        <a href="document-type.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="file-text" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">单据类型</span>
                        </a>
                        <a href="tax-rate.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="percent" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">税率</span>
                        </a>
                        <a href="invoice-type.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="file-invoice" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">发票类型</span>
                        </a>
                        <a href="unit.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="ruler" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">计量单位</span>
                        </a>
                        <a href="requirement-type.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="list-checks" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">需求类型</span>
                        </a>
                        <a href="source-system.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="cloud" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">来源系统</span>
                        </a>
                    </div>
                </div>
                
                <!-- 项目管理 -->
                <div class="mt-4">
                    <div class="menu-header flex items-center justify-between px-4 py-2 cursor-pointer" data-menu="project-management">
                        <h2 class="text-xs font-semibold uppercase tracking-wider">项目管理</h2>
                        <i data-lucide="chevron-down" class="menu-icon w-4 h-4 text-white/70 transition-transform"></i>
                    </div>
                    <div class="menu-content px-2 py-2" id="project-management-content">
                        <a href="project-overview.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="bar-chart-3" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">项目概览</span>
                        </a>
                        <a href="process-acceptance.html" class="sidebar-item flex items-center px-4 py-2 text-white active rounded-md">
                            <i data-lucide="check-circle" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">工序验收管理</span>
                        </a>
                        <a href="accounting-method.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="calculator" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">核算方法管理</span>
                        </a>
                        <a href="project-accounting.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="book" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">项目核算</span>
                        </a>
                    </div>
                </div>
                
                <!-- 应收管理 -->
                <div class="mt-4">
                    <div class="menu-header flex items-center justify-between px-4 py-2 cursor-pointer" data-menu="receivable-management">
                        <h2 class="text-xs font-semibold uppercase tracking-wider">应收管理</h2>
                        <i data-lucide="chevron-down" class="menu-icon w-4 h-4 text-white/70 transition-transform"></i>
                    </div>
                    <div class="menu-content px-2 py-2" id="receivable-management-content">
                        <a href="receivable.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="credit-card" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">应收单</span>
                        </a>
                        <a href="receipt.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="cash" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">收款单</span>
                        </a>
                    </div>
                </div>
            </nav>
        </aside>

        <!-- 主内容区 -->
        <main class="flex-1 ml-64 p-6 transition-all duration-300 overflow-y-auto" id="main-content">
            <div class="bg-white rounded-lg shadow-sm p-6">
                <h2 class="text-2xl font-semibold text-gray-800 mb-6">工序验收管理</h2>
                
                <!-- 搜索和操作区 -->
                <div class="mb-6">
                    <div class="flex flex-nowrap items-center justify-between mb-4">
                        <div class="flex items-center space-x-2 flex-1">
                            <div class="relative flex-1 max-w-md">
                                <select id="filter-field-process" class="absolute left-0 top-0 h-full w-32 pl-3 pr-8 border border-gray-300 rounded-l-md bg-gray-50 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary">
                                    <option value="code">单据编码</option>
                                    <option value="process">工序</option>
                                    <option value="contract">合同号</option>
                                    <option value="status">合同状态</option>
                                    <option value="company">公司</option>
                                </select>
                                <div class="pl-32">
                                    <input type="text" id="filter-value-process" class="w-full px-3 py-2 border border-gray-300 rounded-r-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" placeholder="请输入搜索内容">
                                </div>
                            </div>
                            <button id="advanced-filter-btn-process" class="px-4 py-2 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors flex items-center">
                                <i data-lucide="filter" class="w-4 h-4 mr-2"></i>高级筛选
                            </button>
                        </div>
                        <div class="flex space-x-3">
                            <button id="batch-outbound" class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 transition-colors flex items-center space-x-2">
                                <i data-lucide="package" class="w-4 h-4"></i>
                                <span>批量出库</span>
                            </button>
                            <button id="add-process" class="px-4 py-2 bg-primary text-white rounded-md hover:bg-blue-700 transition-colors flex items-center space-x-2">
                                <i data-lucide="plus" class="w-4 h-4"></i>
                                <span>新增</span>
                            </button>
                        </div>
                    </div>
                    
                    <!-- 高级筛选选项 -->
                    <div id="advanced-filter-process" class="grid grid-cols-1 md:grid-cols-3 gap-4 hidden">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">单据编码</label>
                            <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" placeholder="请输入单据编码">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">工序</label>
                            <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" placeholder="请输入工序">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">合同号</label>
                            <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" placeholder="请输入合同号">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">合同状态</label>
                            <select class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary">
                                <option value="">全部</option>
                                <option value="open">打开</option>
                                <option value="close">关闭</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">公司</label>
                            <select class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary">
                                <option value="">全部</option>
                                <option value="chengdu">成都分公司</option>
                                <option value="langrun">朗润分公司</option>
                            </select>
                        </div>
                        <div class="md:col-span-3 flex justify-end space-x-2 pt-2">
                            <button class="px-4 py-2 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors flex items-center">
                                <i data-lucide="refresh-cw" class="w-4 h-4 mr-2"></i>重置
                            </button>
                            <button class="px-4 py-2 bg-primary text-white rounded-md hover:bg-primary/90 transition-colors">
                                <i data-lucide="search" class="w-4 h-4 mr-2"></i>查询
                            </button>
                        </div>
                    </div>
                </div>
                
                <!-- 数据列表 -->
                <div class="bg-white rounded-lg shadow-sm overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                        <input type="checkbox" class="rounded text-primary focus:ring-primary">
                                    </th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">单据编码</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">公司</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">合同号</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">合同状态</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">工序</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">仓库</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">仓位</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">出库单号</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">操作</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200">
                                <tr>
                                    <td class="px-4 py-3 whitespace-nowrap">
                                        <input type="checkbox" class="rounded text-primary focus:ring-primary" data-id="1">
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">P001</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">成都分公司</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">CON001</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">打开</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">设计</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">成都仓库</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">A区</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">OUT001</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-right text-sm font-medium">
                                        <button class="text-primary hover:text-primary/80 mr-3 generate-outbound-btn" data-id="1">生成出库</button>
                                        <button class="text-primary hover:text-primary/80 view-outbound-btn" data-id="1">查看出库</button>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="px-4 py-3 whitespace-nowrap">
                                        <input type="checkbox" class="rounded text-primary focus:ring-primary" data-id="2">
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">P002</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">朗润分公司</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">CON002</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">打开</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">规划</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">朗润仓库</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">B区</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">OUT002</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-right text-sm font-medium">
                                        <button class="text-primary hover:text-primary/80 mr-3 generate-outbound-btn" data-id="2">生成出库</button>
                                        <button class="text-primary hover:text-primary/80 view-outbound-btn" data-id="2">查看出库</button>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="px-4 py-3 whitespace-nowrap">
                                        <input type="checkbox" class="rounded text-primary focus:ring-primary" data-id="3">
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">P003</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">成都分公司</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">CON003</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">关闭</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">施工</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">成都仓库</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">C区</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-900">-</td>
                                    <td class="px-4 py-3 whitespace-nowrap text-right text-sm font-medium">
                                        <button class="text-primary hover:text-primary/80 mr-3 generate-outbound-btn" data-id="3">生成出库</button>
                                        <button class="text-primary hover:text-primary/80 view-outbound-btn" data-id="3" disabled>查看出库</button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    
                    <!-- 分页 -->
                    <div class="px-4 py-3 flex items-center justify-between border-t border-gray-200 sm:px-6">
                        <div class="flex-1 flex justify-between sm:hidden">
                            <a href="#" class="relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                                上一页
                            </a>
                            <a href="#" class="ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                                下一页
                            </a>
                        </div>
                        <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                            <div>
                                <p class="text-sm text-gray-700">
                                    显示第 <span class="font-medium">1</span> 到 <span class="font-medium">3</span> 条，共 <span class="font-medium">3</span> 条记录
                                </p>
                            </div>
                            <div>
                                <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                                    <a href="#" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                                        <span class="sr-only">上一页</span>
                                        <i data-lucide="chevron-left" class="w-4 h-4"></i>
                                    </a>
                                    <a href="#" aria-current="page" class="z-10 bg-primary border-primary text-white relative inline-flex items-center px-4 py-2 border text-sm font-medium">
                                        1
                                    </a>
                                    <a href="#" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                                        <span class="sr-only">下一页</span>
                                        <i data-lucide="chevron-right" class="w-4 h-4"></i>
                                    </a>
                                </nav>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
        
        <!-- 新增工序验收抽屉 -->
        <div id="process-drawer" class="fixed inset-0 z-50 hidden">
            <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
            <div class="absolute right-0 top-0 bottom-0 w-96 bg-white drawer-shadow overflow-y-auto">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-6">
                        <h3 id="drawer-title" class="text-lg font-semibold text-gray-800">新增工序验收</h3>
                        <button id="close-drawer" class="p-2 rounded-md hover:bg-gray-100">
                            <i data-lucide="x" class="w-5 h-5 text-gray-500"></i>
                        </button>
                    </div>
                    <form id="process-form">
                        <input type="hidden" id="process-id">
                        <div class="space-y-4">
                            <div>
                                <label for="process-code" class="block text-sm font-medium text-gray-700 mb-1">单据编码 *</label>
                                <input type="text" id="process-code" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" placeholder="请输入单据编码">
                            </div>
                            <div>
                                <label for="process-company" class="block text-sm font-medium text-gray-700 mb-1">公司 *</label>
                                <select id="process-company" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary">
                                    <option value="">请选择公司</option>
                                    <option value="chengdu">成都分公司</option>
                                    <option value="langrun">朗润分公司</option>
                                </select>
                            </div>
                            <div>
                                <label for="process-contract" class="block text-sm font-medium text-gray-700 mb-1">合同号 *</label>
                                <input type="text" id="process-contract" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" placeholder="请输入合同号">
                            </div>
                            <div>
                                <label for="process-contract-status" class="block text-sm font-medium text-gray-700 mb-1">合同状态 *</label>
                                <select id="process-contract-status" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary">
                                    <option value="">请选择合同状态</option>
                                    <option value="open">打开</option>
                                    <option value="close">关闭</option>
                                </select>
                            </div>
                            <div>
                                <label for="process-name" class="block text-sm font-medium text-gray-700 mb-1">工序 *</label>
                                <input type="text" id="process-name" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" placeholder="请输入工序">
                            </div>
                            <div>
                                <label for="process-warehouse" class="block text-sm font-medium text-gray-700 mb-1">仓库 *</label>
                                <input type="text" id="process-warehouse" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" placeholder="请输入仓库">
                            </div>
                            <div>
                                <label for="process-location" class="block text-sm font-medium text-gray-700 mb-1">仓位 *</label>
                                <input type="text" id="process-location" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" placeholder="请输入仓位">
                            </div>
                            <div>
                                <label for="process-outbound" class="block text-sm font-medium text-gray-700 mb-1">出库单号</label>
                                <input type="text" id="process-outbound" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" placeholder="请输入出库单号" readonly>
                            </div>
                        </div>
                        <div class="mt-8 flex justify-end space-x-3">
                            <button type="button" id="cancel-form" class="px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50">
                                取消
                            </button>
                            <button type="submit" class="px-4 py-2 bg-primary text-white rounded-md hover:bg-primary/90">
                                保存
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        
        <!-- 生成出库确认弹窗 -->
        <div id="generate-outbound-modal" class="fixed inset-0 z-50 hidden">
            <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
            <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-white rounded-lg shadow-lg p-6 w-full max-w-md">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-gray-800">生成出库确认</h3>
                    <button class="close-modal-btn p-2 rounded-md hover:bg-gray-100">
                        <i data-lucide="x" class="w-5 h-5 text-gray-500"></i>
                    </button>
                </div>
                <p class="text-gray-700 mb-6">确定要为选中的工序验收记录生成出库单吗？</p>
                <div class="flex justify-end space-x-3">
                    <button class="close-modal-btn px-4 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50">
                        取消
                    </button>
                    <button id="confirm-generate" class="px-4 py-2 bg-primary text-white rounded-md hover:bg-primary/90">
                        确定
                    </button>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        // 初始化Lucide图标
        lucide.createIcons();
        
        // 侧边栏折叠/展开功能
        const toggleSidebar = document.getElementById('toggle-sidebar');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('main-content');
        
        toggleSidebar.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
            if (sidebar.classList.contains('collapsed')) {
                mainContent.classList.remove('ml-64');
                mainContent.classList.add('ml-16');
            } else {
                mainContent.classList.remove('ml-16');
                mainContent.classList.add('ml-64');
            }
        });
        
        // 菜单展开/收拢功能
        const menuHeaders = document.querySelectorAll('.menu-header');
        
        menuHeaders.forEach(header => {
            header.addEventListener('click', () => {
                const menuName = header.getAttribute('data-menu');
                const content = document.getElementById(`${menuName}-content`);
                const icon = header.querySelector('.menu-icon');
                
                // 切换内容显示/隐藏
                content.classList.toggle('hidden');
                
                // 切换图标旋转
                if (content.classList.contains('hidden')) {
                    icon.style.transform = 'rotate(0deg)';
                } else {
                    icon.style.transform = 'rotate(180deg)';
                }
            });
        });
        
        // 高亮当前页面的导航项
        const currentPath = window.location.pathname;
        const sidebarItems = document.querySelectorAll('.sidebar-item');
        
        sidebarItems.forEach(item => {
            const href = item.getAttribute('href');
            if (currentPath.includes(href)) {
                item.classList.add('active');
                
                // 展开包含当前页面的菜单
                const menuContent = item.closest('.menu-content');
                if (menuContent) {
                    menuContent.classList.remove('hidden');
                    const menuHeader = menuContent.previousElementSibling;
                    if (menuHeader) {
                        const icon = menuHeader.querySelector('.menu-icon');
                        if (icon) {
                            icon.style.transform = 'rotate(180deg)';
                        }
                    }
                }
            }
        });
        
        // 抽屉操作
        const addProcessBtn = document.getElementById('add-process');
        const processDrawer = document.getElementById('process-drawer');
        const closeDrawerBtn = document.getElementById('close-drawer');
        const cancelFormBtn = document.getElementById('cancel-form');
        const drawerTitle = document.getElementById('drawer-title');
        
        // 打开新增抽屉
        addProcessBtn.addEventListener('click', () => {
            drawerTitle.textContent = '新增工序验收';
            document.getElementById('process-id').value = '';
            document.getElementById('process-code').value = '';
            document.getElementById('process-company').value = '';
            document.getElementById('process-contract').value = '';
            document.getElementById('process-contract-status').value = '';
            document.getElementById('process-name').value = '';
            document.getElementById('process-warehouse').value = '';
            document.getElementById('process-location').value = '';
            document.getElementById('process-outbound').value = '';
            processDrawer.classList.remove('hidden');
        });
        
        // 关闭抽屉
        closeDrawerBtn.addEventListener('click', () => {
            processDrawer.classList.add('hidden');
        });
        
        cancelFormBtn.addEventListener('click', () => {
            processDrawer.classList.add('hidden');
        });
        
        // 点击抽屉外部关闭
        processDrawer.addEventListener('click', (e) => {
            if (e.target === processDrawer) {
                processDrawer.classList.add('hidden');
            }
        });
        
        // 表单提交
        const processForm = document.getElementById('process-form');
        processForm.addEventListener('submit', (e) => {
            e.preventDefault();
            
            const id = document.getElementById('process-id').value;
            const code = document.getElementById('process-code').value;
            const company = document.getElementById('process-company').value;
            const contract = document.getElementById('process-contract').value;
            const contractStatus = document.getElementById('process-contract-status').value;
            const name = document.getElementById('process-name').value;
            const warehouse = document.getElementById('process-warehouse').value;
            const location = document.getElementById('process-location').value;
            
            // 模拟提交
            alert(id ? '编辑成功！' : '新增成功！');
            processDrawer.classList.add('hidden');
        });
        
        // 生成出库确认
        const generateOutboundModal = document.getElementById('generate-outbound-modal');
        const closeModalBtns = document.querySelectorAll('.close-modal-btn');
        const confirmGenerateBtn = document.getElementById('confirm-generate');
        let currentGenerateId = null;
        
        // 打开生成出库确认弹窗
        const generateOutboundBtns = document.querySelectorAll('.generate-outbound-btn');
        generateOutboundBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                currentGenerateId = btn.getAttribute('data-id');
                generateOutboundModal.classList.remove('hidden');
            });
        });
        
        // 批量出库
        const batchOutboundBtn = document.getElementById('batch-outbound');
        batchOutboundBtn.addEventListener('click', () => {
            const checkedBoxes = document.querySelectorAll('input[type="checkbox"][data-id]:checked');
            if (checkedBoxes.length === 0) {
                alert('请选择要批量出库的记录');
                return;
            }
            generateOutboundModal.classList.remove('hidden');
        });
        
        // 关闭确认弹窗
        closeModalBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                generateOutboundModal.classList.add('hidden');
                currentGenerateId = null;
            });
        });
        
        // 点击弹窗外部关闭
        generateOutboundModal.addEventListener('click', (e) => {
            if (e.target === generateOutboundModal) {
                generateOutboundModal.classList.add('hidden');
                currentGenerateId = null;
            }
        });
        
        // 确认生成出库
        confirmGenerateBtn.addEventListener('click', () => {
            // 模拟生成出库
            alert('出库单生成成功！');
            generateOutboundModal.classList.add('hidden');
            currentGenerateId = null;
        });
        
        // 查看出库
        const viewOutboundBtns = document.querySelectorAll('.view-outbound-btn');
        viewOutboundBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                if (!btn.hasAttribute('disabled')) {
                    alert('跳转到出库单查看页面');
                }
            });
        });
        
        // 高级筛选功能
        const advancedFilterBtnProcess = document.getElementById('advanced-filter-btn-process');
        const advancedFilterProcess = document.getElementById('advanced-filter-process');
        
        advancedFilterBtnProcess.addEventListener('click', function() {
            advancedFilterProcess.classList.toggle('hidden');
        });
    </script>
</body>
</html>