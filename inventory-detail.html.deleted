                                        <td class="px-4 py-2 text-sm text-gray-700">采购入库单</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">WL001</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">木材</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">P2026040801</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">主仓库</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">A区01架</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">10</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">根</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">200.00</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">180.00</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">DZD2604150001</td>
                                        <td class="px-4 py-2 text-sm">
                                            <span class="px-2 py-1 text-xs font-medium rounded-full bg-green-100 text-green-800">对账成功</span>
                                        </td>
                                        <td class="px-4 py-2 text-sm text-gray-700">金蝶</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">CKD2604150001</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">2026-04-08 10:30</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">2026-04-08 10:30</td>
                                    </tr>
                                    <tr>
                                        <td class="px-4 py-2 text-sm text-gray-700">财务主体1</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">2026-04</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">HT202603001</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">2026-04-10</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">2026-04-07</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">RKD2604070001</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">采购入库单</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">WL002</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">板材</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">P2026040701</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">辅料仓</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">B区03架</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">5</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">张</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">300.00</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">280.00</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">DZD2604150001</td>
                                        <td class="px-4 py-2 text-sm">
                                            <span class="px-2 py-1 text-xs font-medium rounded-full bg-yellow-100 text-yellow-800">待对账</span>
                                        </td>
                                        <td class="px-4 py-2 text-sm text-gray-700">金蝶</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">-</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">2026-04-07 14:20</td>
                                        <td class="px-4 py-2 text-sm text-gray-700">2026-04-07 14:20</td>
