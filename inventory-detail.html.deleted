                        <div id="advanced-filter-business" class="hidden bg-gray-50 p-4 rounded-md border border-gray-200 mb-6">
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 mb-1">财务主体</label>
