    <script>
        async function loadSidebar() {
            try {
                const response = await fetch('common/sidebar.html');
                const sidebarHtml = await response.text();
                document.getElementById('sidebar-container').innerHTML = sidebarHtml;
                
                setTimeout(() => {
                    const script = document.createElement('script');
                    script.src = 'common/scripts.js';
                    script.onload = function() {
                        if (typeof initCommonFunctions === 'function') {
                            initCommonFunctions();
                        }
                        initPageFunctions();
                    };
                    document.body.appendChild(script);
                }, 100);
            } catch (error) {
                console.error('加载侧边栏失败:', error);
            }
        }
        
        function initPageFunctions() {
            const tabs = {
                'kingdee': 'content-kingdee',
                'business': 'content-business',
                'ebs': 'content-ebs'
            };

            Object.keys(tabs).forEach(tabId => {
                document.getElementById(`tab-${tabId}`)?.addEventListener('click', function() {
                    Object.keys(tabs).forEach(id => {
                        const tabBtn = document.getElementById(`tab-${id}`);
                        const tabContent = document.getElementById(tabs[id]);
                        if (id === tabId) {
                            tabBtn?.classList.add('border-primary', 'text-primary', 'font-medium');
                            tabBtn?.classList.remove('border-transparent', 'text-gray-500');
                            tabContent?.classList.remove('hidden');
                        } else {
                            tabBtn?.classList.remove('border-primary', 'text-primary', 'font-medium');
                            tabBtn?.classList.add('border-transparent', 'text-gray-500');
                            tabContent?.classList.add('hidden');
                        }
                    });
                });
            });

            const tabNames = ['kingdee', 'business', 'ebs'];
            tabNames.forEach(tabName => {
                const exportBtn = document.getElementById(`export-${tabName}`);
                exportBtn?.addEventListener('click', () => {
                    alert('导出功能执行中...');
                });

                const filterSelect = document.getElementById(`filter-field-${tabName}`);
                const filterInput = document.getElementById(`filter-value-${tabName}`);
                
                filterSelect?.addEventListener('change', function() {
                    const selectedValue = this.value;
                    const placeholders = {
                        'entity': '按财务主体搜索',
                        'contract': '按合同号搜索',
                        'material': '按物料编码搜索',
                        'docType': '按单据类型搜索',
                        'period': '按会计期间搜索',
                        'stockDate': '按库存截止日期搜索'
                    };
                    filterInput.placeholder = placeholders[selectedValue] || '搜索';
                    filterInput.value = '';
                });

                const advancedFilterBtn = document.getElementById(`advanced-filter-btn-${tabName}`);
                const advancedFilter = document.getElementById(`advanced-filter-${tabName}`);
                
                advancedFilterBtn?.addEventListener('click', function() {
                    advancedFilter.classList.toggle('hidden');
                    if (!advancedFilter.classList.contains('hidden')) {
                        this.innerHTML = '收起筛选 <i data-lucide="chevron-up" class="w-4 h-4 ml-1"></i>';
                    } else {
                        this.innerHTML = '高级筛选 <i data-lucide="chevron-down" class="w-4 h-4 ml-1"></i>';
                    }
                    lucide.createIcons();
                });
            });
        }
        
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', loadSidebar);
        } else {
            loadSidebar();
        }
    </script>
    <div id="req-tooltip-container"></div>
    <script src="js/req-annotation.js"></script>
</body>
</html>
