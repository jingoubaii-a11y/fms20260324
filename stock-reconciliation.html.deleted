<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>软装三方对账 - 财务中台</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#003eb3',
                        secondary: '#e6f0ff',
                        accent: '#ff6b6b',
                        neutral: '#f5f7fa',
                    },
                    borderRadius: {
                        'sm': '4px',
                        'md': '8px',
                        'lg': '12px',
                        'xl': '16px',
                    },
                },
            }
        }
    </script>
    <link rel="stylesheet" href="common/styles.css">
</head>
<body class="bg-neutral">
    <div class="flex h-screen">
        <div id="sidebar-container"></div>
        <main class="flex-1 ml-64 p-6 transition-all duration-300 overflow-y-auto" id="main-content">
            <div class="space-y-6">
                <div class="bg-white rounded-lg shadow-sm p-6">
                    <h1 class="text-xl font-semibold text-gray-800">软装三方对账</h1>
                </div>

                <div class="bg-white rounded-lg shadow-sm p-6">
                    <!-- 筛选条件和按钮栏 -->
                    <div class="flex items-center justify-between mb-6 flex-nowrap">
                        <div class="flex items-center space-x-2 flex-1">
                            <select id="filter-field-stock-reconciliation" class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                <option value="code">对账单号</option>
                                <option value="contract">合同号</option>
                                <option value="entity">财务主体</option>
                                <option value="result">对账结果</option>
                            </select>
                            <input type="text" id="filter-value-stock-reconciliation" placeholder="按对账单号搜索" class="w-64 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                            <button class="px-3 py-2 bg-gray-100 border border-gray-300 rounded-md hover:bg-gray-200 transition-colors">
                                <i data-lucide="search" class="w-4 h-4"></i>
                            </button>
                            <button class="px-3 py-2 bg-gray-100 border border-gray-300 rounded-md hover:bg-gray-200 transition-colors">
                                <i data-lucide="refresh-ccw" class="w-4 h-4"></i>
                            </button>
                            <button id="advanced-filter-btn-stock-reconciliation" class="px-3 py-2 text-primary hover:bg-secondary rounded-md transition-colors flex items-center">
                                高级筛选
                                <i data-lucide="chevron-down" class="w-4 h-4 ml-1"></i>
                            </button>
                        </div>
                        <div class="flex items-center space-x-3">
                            <button id="batch-reconciliation" class="px-4 py-2 bg-gray-100 border border-gray-300 rounded-md hover:bg-gray-200">批量对账</button>
                            <button id="batch-outbound" class="px-4 py-2 bg-gray-100 border border-gray-300 rounded-md hover:bg-gray-200">批量出库</button>
                            <button id="add-reconciliation" class="px-4 py-2 bg-primary text-white rounded-md hover:bg-blue-700 flex items-center">
                                <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
                                新增
                            </button>
                        </div>
                    </div>
                    
                    <!-- 高级筛选展开区域 -->
                    <div id="advanced-filter-stock-reconciliation" class="hidden bg-gray-50 p-4 rounded-md border border-gray-200 mb-6">
                        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">对账单号</label>
                                <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">合同号</label>
                                <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">财务主体</label>
                                <select class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                    <option value="">全部</option>
                                    <option value="org1">财务主体1</option>
                                    <option value="org2">财务主体2</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">对账结果</label>
                                <select class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                                    <option value="">全部</option>
                                    <option value="success">对账成功</option>
                                    <option value="failed">对账失败</option>
                                </select>
                            </div>
                        </div>
                        <div class="mt-4 flex justify-end space-x-2">
                            <button class="px-4 py-2 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors">
                                重置
                            </button>
                            <button class="px-4 py-2 bg-primary text-white rounded-md hover:bg-blue-700 transition-colors">
                                查询
                            </button>
                        </div>
                    </div>

                    <div class="overflow-x-auto">
                        <table class="min-w-full bg-white border border-gray-200 rounded-lg">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">对账单号</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">合同号</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">财务主体</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">单据类型</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">收入核算期间</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">财务确认竣工时间</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">是否出库</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">出库单号</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">对账状态</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">对账时间</th>
                                    <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">操作</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200">
                                <tr>
                                    <td class="px-4 py-2 text-sm text-gray-700">DZD2604150001</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">HT202603001</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">财务主体1</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">竣工出库对账</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">2026-04</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">2026-04-10</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">是</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">XSCK260415001</td>
                                    <td class="px-4 py-2 text-sm">
                                        <span class="px-2 py-1 text-xs font-medium rounded-full bg-green-100 text-green-800">对账成功</span>
                                    </td>
                                    <td class="px-4 py-2 text-sm text-gray-700">2026-04-15 10:30</td>
                                    <td class="px-4 py-2 text-sm">
                                        <div class="flex space-x-2">
                                            <button class="text-primary hover:text-blue-700 view-detail">详情</button>
                                            <button class="text-gray-500 hover:text-gray-700 inventory-detail">库存明细</button>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="px-4 py-2 text-sm text-gray-700">DZD2604140001</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">HT202603002</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">财务主体1</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">竣工出库对账</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">2026-04</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">2026-04-08</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">否</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">-</td>
                                    <td class="px-4 py-2 text-sm">
                                        <span class="px-2 py-1 text-xs font-medium rounded-full bg-red-100 text-red-800">对账失败</span>
                                    </td>
                                    <td class="px-4 py-2 text-sm text-gray-700">2026-04-14 15:45</td>
                                    <td class="px-4 py-2 text-sm">
                                        <div class="flex space-x-2">
                                            <button class="text-primary hover:text-blue-700 view-detail">详情</button>
                                            <button class="text-primary hover:text-blue-700 reconciliation">对账</button>
                                            <button class="text-gray-500 hover:text-gray-700 inventory-detail">库存明细</button>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="px-4 py-2 text-sm text-gray-700">DZD2604130001</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">HT202603003</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">财务主体2</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">竣工出库对账</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">2026-04</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">2026-04-05</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">否</td>
                                    <td class="px-4 py-2 text-sm text-gray-700">-</td>
                                    <td class="px-4 py-2 text-sm">
                                        <span class="px-2 py-1 text-xs font-medium rounded-full bg-green-100 text-green-800">对账成功</span>
                                    </td>
                                    <td class="px-4 py-2 text-sm text-gray-700">2026-04-13 09:20</td>
                                    <td class="px-4 py-2 text-sm">
                                        <div class="flex space-x-2">
                                            <button class="text-primary hover:text-blue-700 view-detail">详情</button>
                                            <button class="text-primary hover:text-blue-700 outbound">出库</button>
                                            <button class="text-gray-500 hover:text-gray-700 inventory-detail">库存明细</button>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-6 flex items-center justify-between">
                        <div class="text-sm text-gray-500">
                            显示 1-3 条，共 3 条
                        </div>
                        <div class="flex space-x-1">
                            <button class="px-3 py-1 border border-gray-300 rounded-md text-sm text-gray-500 hover:bg-gray-50 disabled:opacity-50" disabled>上一页</button>
                            <button class="px-3 py-1 border border-primary bg-primary text-white rounded-md text-sm">1</button>
                            <button class="px-3 py-1 border border-gray-300 rounded-md text-sm text-gray-500 hover:bg-gray-50 disabled:opacity-50" disabled>下一页</button>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="reconciliation-drawer" class="drawer fixed top-0 right-0 h-full w-96 bg-white shadow-lg z-50 overflow-y-auto">
        <div class="p-6">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-lg font-semibold text-gray-900">新增软装三方对账</h3>
                <button id="close-drawer" class="text-gray-400 hover:text-gray-600">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            
            <form id="reconciliation-form" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">财务主体 <span class="text-red-500">*</span></label>
                    <select class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary">
                        <option value="">请选择财务主体</option>
                        <option value="org1">财务主体1</option>
                        <option value="org2">财务主体2</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">财务确认竣工日期 <span class="text-red-500">*</span></label>
                    <input type="date" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">合同号 <span class="text-red-500">*</span></label>
                    <input type="text" placeholder="请输入合同号" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary">
                </div>
            </form>
            
            <div class="mt-6 flex justify-end space-x-3">
                <button id="cancel-drawer" class="px-4 py-2 bg-white border border-gray-300 rounded-md hover:bg-gray-50">取消</button>
                <button id="confirm-drawer" class="px-4 py-2 bg-primary text-white rounded-md hover:bg-blue-700">确认</button>
            </div>
        </div>
    </div>
    
    <div id="drawer-overlay" class="drawer-overlay"></div>

    <div id="detail-modal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
        <div class="bg-white rounded-lg shadow-lg w-full max-w-4xl mx-4 max-h-[90vh] overflow-y-auto">
            <div class="p-6 border-b border-gray-200 flex justify-between items-center">
                <h3 class="text-lg font-semibold text-gray-900">对账详情</h3>
                <button id="close-detail-modal" class="text-gray-400 hover:text-gray-600">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            <div class="p-6">
                <div class="mb-6">
                    <h4 class="text-md font-medium text-gray-800 mb-3">业务与金蝶对账</h4>
                    <div class="overflow-x-auto">
                        <table class="min-w-full bg-white border border-gray-200 rounded-lg">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">财务主体</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">合同号</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">物料编码</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">业务系统</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">业务数量</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">金蝶数量</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">比对结果</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200">
                                <tr>
                                    <td class="px-3 py-2 text-sm text-gray-700">财务主体1</td>
                                    <td class="px-3 py-2 text-sm text-gray-700">HT202603001</td>
                                    <td class="px-3 py-2 text-sm text-gray-700">WL001</td>
                                    <td class="px-3 py-2 text-sm text-gray-700">积木云装</td>
                                    <td class="px-3 py-2 text-sm text-gray-700">10</td>
                                    <td class="px-3 py-2 text-sm text-gray-700">10</td>
                                    <td class="px-3 py-2 text-sm">
                                        <span class="text-green-600">匹配</span>
                                    </td>
                                </tr>
                                <tr class="bg-red-50">
                                    <td class="px-3 py-2 text-sm text-gray-700">财务主体1</td>
                                    <td class="px-3 py-2 text-sm text-gray-700">HT202603001</td>
                                    <td class="px-3 py-2 text-sm text-gray-700">WL002</td>
                                    <td class="px-3 py-2 text-sm text-gray-700">积木云装</td>
                                    <td class="px-3 py-2 text-sm text-red-700">5</td>
                                    <td class="px-3 py-2 text-sm text-red-700">3</td>
                                    <td class="px-3 py-2 text-sm">
                                        <span class="text-red-600">数量差异</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div>
                    <h4 class="text-md font-medium text-gray-800 mb-3">金蝶与EBS对账</h4>
                    <div class="overflow-x-auto">
                        <table class="min-w-full bg-white border border-gray-200 rounded-lg">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">财务主体</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">收入核算期间</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">合同号</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">物料编码</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">金蝶数量</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">EBS数量</th>
                                    <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">比对结果</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200">
                                <tr>
                                    <td class="px-3 py-2 text-sm text-gray-700">财务主体1</td>
                                    <td class="px-3 py-2 text-sm text-gray-700">2026-04</td>
                                    <td class="px-3 py-2 text-sm text-gray-700">HT202603001</td>
                                    <td class="px-3 py-2 text-sm text-gray-700">WL001</td>
                                    <td class="px-3 py-2 text-sm text-gray-700">10</td>
                                    <td class="px-3 py-2 text-sm text-gray-700">10</td>
                                    <td class="px-3 py-2 text-sm">
                                        <span class="text-green-600">匹配</span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="p-6 border-t border-gray-200 flex justify-end">
                <button id="close-detail-btn" class="px-4 py-2 bg-white border border-gray-300 rounded-md hover:bg-gray-50">关闭</button>
            </div>
        </div>
    </div>

    <script>
        async function loadSidebar() {
            try {
                const response = await fetch('common/sidebar.html');
                const sidebarHtml = await response.text();
                document.getElementById('sidebar-container').innerHTML = sidebarHtml;
                
                setTimeout(() => {
                    const script = document.createElement('script');
                    script.src = 'common/scripts.js';
                    script.onload = function() {
                        if (typeof initCommonFunctions === 'function') {
                            initCommonFunctions();
                        }
                        initPageFunctions();
                    };
                    document.body.appendChild(script);
                }, 100);
            } catch (error) {
                console.error('加载侧边栏失败:', error);
            }
        }
        
        function initPageFunctions() {
            const reconciliationDrawer = document.getElementById('reconciliation-drawer');
            const detailModal = document.getElementById('detail-modal');
            
            // 筛选条件选择器功能
            const filterSelect = document.getElementById('filter-field-stock-reconciliation');
            const filterInput = document.getElementById('filter-value-stock-reconciliation');
            
            filterSelect.addEventListener('change', function() {
                const selectedValue = this.value;
                
                // 根据选择的筛选条件更新占位符
                if (selectedValue === 'code') {
                    filterInput.placeholder = '按对账单号搜索';
                } else if (selectedValue === 'contract') {
                    filterInput.placeholder = '按合同号搜索';
                } else if (selectedValue === 'entity') {
                    filterInput.placeholder = '按财务主体搜索';
                } else if (selectedValue === 'result') {
                    filterInput.placeholder = '按对账结果搜索';
                }
                
                // 清空输入框
                filterInput.value = '';
            });
            
            // 高级筛选功能
            const advancedFilterBtn = document.getElementById('advanced-filter-btn-stock-reconciliation');
            const advancedFilter = document.getElementById('advanced-filter-stock-reconciliation');
            
            advancedFilterBtn.addEventListener('click', function() {
                advancedFilter.classList.toggle('hidden');
                
                // 切换按钮文本和图标
                if (!advancedFilter.classList.contains('hidden')) {
                    this.innerHTML = '收起筛选 <i data-lucide="chevron-up" class="w-4 h-4 ml-1"></i>';
                } else {
                    this.innerHTML = '高级筛选 <i data-lucide="chevron-down" class="w-4 h-4 ml-1"></i>';
                }
                
                // 重新初始化图标
                lucide.createIcons();
            });
            
            document.getElementById('add-reconciliation').addEventListener('click', () => {
                if (typeof openDrawer === 'function') {
                    openDrawer(reconciliationDrawer);
                } else {
                    reconciliationDrawer.classList.add('open');
                    document.getElementById('drawer-overlay').classList.add('open');
                }
            });
            
            document.getElementById('close-drawer').addEventListener('click', () => {
                if (typeof closeDrawer === 'function') {
                    closeDrawer(reconciliationDrawer);
                } else {
                    reconciliationDrawer.classList.remove('open');
                    document.getElementById('drawer-overlay').classList.remove('open');
                }
            });
            
            document.getElementById('cancel-drawer').addEventListener('click', () => {
                if (typeof closeDrawer === 'function') {
                    closeDrawer(reconciliationDrawer);
                } else {
                    reconciliationDrawer.classList.remove('open');
                    document.getElementById('drawer-overlay').classList.remove('open');
                }
            });
            
            document.getElementById('confirm-drawer').addEventListener('click', () => {
                alert('对账新增成功');
                if (typeof closeDrawer === 'function') {
                    closeDrawer(reconciliationDrawer);
                } else {
                    reconciliationDrawer.classList.remove('open');
                    document.getElementById('drawer-overlay').classList.remove('open');
                }
            });
            
            document.querySelectorAll('.view-detail').forEach(btn => {
                btn.addEventListener('click', () => {
                    detailModal.classList.remove('hidden');
                });
            });
            
            document.getElementById('close-detail-modal').addEventListener('click', () => {
                detailModal.classList.add('hidden');
            });
            
            document.getElementById('close-detail-btn').addEventListener('click', () => {
                detailModal.classList.add('hidden');
            });
            
            detailModal.addEventListener('click', (e) => {
                if (e.target === detailModal) {
                    detailModal.classList.add('hidden');
                }
            });
            
            document.querySelectorAll('.reconciliation').forEach(btn => {
                btn.addEventListener('click', () => {
                    alert('对账功能执行中...');
                });
            });
            
            document.querySelectorAll('.outbound').forEach(btn => {
                btn.addEventListener('click', () => {
                    alert('出库功能执行中...');
                });
            });
            
            document.querySelectorAll('.inventory-detail').forEach(btn => {
                btn.addEventListener('click', () => {
                    window.location.href = 'inventory-detail.html';
                });
            });
            
            document.getElementById('batch-reconciliation').addEventListener('click', () => {
                alert('批量对账功能执行中...');
            });
            
            document.getElementById('batch-outbound').addEventListener('click', () => {
                alert('批量出库功能执行中...');
            });
        }
        
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', loadSidebar);
        } else {
            loadSidebar();
        }
    </script>
</body>
</html>
