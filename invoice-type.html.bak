<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>发票类型 - 财务中台</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#003eb3',
                        secondary: '#e6f0ff',
                        accent: '#ff6b6b',
                        neutral: '#f5f7fa',
                    },
                    borderRadius: {
                        'sm': '4px',
                        'md': '8px',
                        'lg': '12px',
                        'xl': '16px',
                    },
                },
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
        }
        
        .sidebar {
            transition: width 0.3s ease-in-out;
        }
        
        .sidebar.collapsed {
            width: 64px;
        }
        
        .sidebar.collapsed .sidebar-text {
            display: none;
        }
        
        .sidebar.collapsed .sidebar-icon {
            margin: 0 auto;
        }
        
        .sidebar-item {
            transition: all 0.2s ease-in-out;
            font-size: 0.875rem;
        }
        
        .sidebar-item:hover {
            background-color: rgba(255, 255, 255, 0.1);
        }
        
        .sidebar-item.active {
            background-color: rgba(255, 255, 255, 0.2);
            color: white;
            font-weight: 500;
        }
        
        .gradient-bg {
            background: linear-gradient(135deg, #003eb3 0%, #0056c7 100%);
        }
        
        .menu-header h2 {
            font-size: 0.875rem;
            color: rgba(255, 255, 255, 0.7);
        }
        
        .drawer {
            transition: transform 0.3s ease-in-out;
            transform: translateX(100%);
        }
        
        .drawer.open {
            transform: translateX(0);
        }
        
        .drawer-overlay {
            transition: opacity 0.3s ease;
            opacity: 0;
            pointer-events: none;
        }
        
        .drawer-overlay.open {
            opacity: 1;
            pointer-events: auto;
        }
        
        .switch {
            position: relative;
            display: inline-block;
            width: 44px;
            height: 24px;
        }
        
        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }
        
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: .4s;
            border-radius: 24px;
        }
        
        .slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }
        
        input:checked + .slider {
            background-color: #003eb3;
        }
        
        input:checked + .slider:before {
            transform: translateX(20px);
        }
    </style>
</head>
<body class="bg-neutral min-h-screen">
    <!-- 主容器 -->
    <div class="flex h-screen">
        <!-- 侧边栏 -->
        <aside id="sidebar" class="sidebar gradient-bg text-white shadow-sm fixed left-0 top-0 bottom-0 w-64 overflow-y-auto z-10">
            <div class="p-4 flex items-center justify-between border-b border-white/20">
                <h1 class="text-xl font-semibold">财务中台</h1>
                <button id="toggle-sidebar" class="p-2 rounded-md hover:bg-white/10">
                    <i data-lucide="menu"></i>
                </button>
            </div>
            <nav class="py-4">
                <!-- 仪表盘 -->
                <a href="index.html" class="sidebar-item flex items-center px-4 py-3 text-white/90 hover:text-white rounded-md">
                    <i data-lucide="home" class="sidebar-icon w-5 h-5 mr-3"></i>
                    <span class="sidebar-text">仪表盘</span>
                </a>
                
                <!-- 基础资料 -->
                <div class="mt-4">
                    <div class="menu-header flex items-center justify-between px-4 py-2 cursor-pointer" data-menu="basic-data">
                        <h2 class="text-xs font-semibold uppercase tracking-wider">基础资料</h2>
                        <i data-lucide="chevron-down" class="menu-icon w-4 h-4 text-white/70 transition-transform"></i>
                    </div>
                    <div class="menu-content px-2 py-2" id="basic-data-content">
                        <a href="financial-entity.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="building" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">财务主体</span>
                        </a>
                        <a href="merchant.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="users" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">客商</span>
                        </a>
                        <a href="project.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="clipboard-list" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">项目</span>
                        </a>
                        <a href="material.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="package" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">物料</span>
                        </a>
                        <a href="cost-ratio.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="pie-chart" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">成本比例配置</span>
                        </a>
                    </div>
                </div>
                
                <!-- 公共资料 -->
                <div class="mt-4">
                    <div class="menu-header flex items-center justify-between px-4 py-2 cursor-pointer" data-menu="public-data">
                        <h2 class="text-xs font-semibold uppercase tracking-wider">公共资料</h2>
                        <i data-lucide="chevron-down" class="menu-icon w-4 h-4 text-white/70 transition-transform"></i>
                    </div>
                    <div class="menu-content px-2 py-2" id="public-data-content">
                        <a href="currency.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="dollar-sign" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">币别</span>
                        </a>
                        <a href="accounting-calendar.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="calendar" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">会计日历</span>
                        </a>
                        <a href="document-type.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="file-text" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">单据类型</span>
                        </a>
                        <a href="tax-rate.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="percent" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">税率</span>
                        </a>
                        <a href="invoice-type.html" class="sidebar-item flex items-center px-4 py-2 text-white active rounded-md">
                            <i data-lucide="file-invoice" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">发票类型</span>
                        </a>
                        <a href="unit.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="ruler" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">计量单位</span>
                        </a>
                        <a href="requirement-type.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="list-checks" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">需求类型</span>
                        </a>
                        <a href="source-system.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="cloud" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">来源系统</span>
                        </a>
                    </div>
                </div>
                
                <!-- 项目管理 -->
                <div class="mt-4">
                    <div class="menu-header flex items-center justify-between px-4 py-2 cursor-pointer" data-menu="project-management">
                        <h2 class="text-xs font-semibold uppercase tracking-wider">项目管理</h2>
                        <i data-lucide="chevron-down" class="menu-icon w-4 h-4 text-white/70 transition-transform"></i>
                    </div>
                    <div class="menu-content px-2 py-2" id="project-management-content">
                        <a href="project-overview.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="bar-chart-3" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">项目概览</span>
                        </a>
                        <a href="process-acceptance.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="check-circle" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">工序验收管理</span>
                        </a>
                        <a href="accounting-method.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="calculator" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">核算方法管理</span>
                        </a>
                        <a href="project-accounting.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="book" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">项目核算</span>
                        </a>
                    </div>
                </div>
                
                <!-- 应收管理 -->
                <div class="mt-4">
                    <div class="menu-header flex items-center justify-between px-4 py-2 cursor-pointer" data-menu="receivable-management">
                        <h2 class="text-xs font-semibold uppercase tracking-wider">应收管理</h2>
                        <i data-lucide="chevron-down" class="menu-icon w-4 h-4 text-white/70 transition-transform"></i>
                    </div>
                    <div class="menu-content px-2 py-2" id="receivable-management-content">
                        <a href="receivable.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="credit-card" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">应收单</span>
                        </a>
                        <a href="receipt.html" class="sidebar-item flex items-center px-4 py-2 text-white/90 hover:text-white rounded-md">
                            <i data-lucide="cash" class="sidebar-icon w-4 h-4 mr-3"></i>
                            <span class="sidebar-text">收款单</span>
                        </a>
                    </div>
                </div>
            </nav>
        </aside>

        <!-- 主内容区 -->
        <main class="flex-1 ml-64 p-6 transition-all duration-300 overflow-y-auto" id="main-content">
            <div class="bg-white rounded-lg shadow-sm p-6">
                <div class="border-b border-gray-200 pb-4 mb-6">
                    <h1 class="text-xl font-semibold text-gray-800">发票类型</h1>
                </div>
                
                <!-- 搜索条件和按钮 -->
                <div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div class="flex-1 flex items-center space-x-2">
                        <!-- 筛选条件选择器 -->
                        <select id="filter-select" class="px-3 py-2 border border-gray-300 rounded-md focus:outline-none text-sm">
                            <option value="code">发票类型编码</option>
                            <option value="name">发票类型名称</option>
                            <option value="status">状态</option>
                        </select>
                        
                        <!-- 输入框 -->
                        <input type="text" id="filter-input" placeholder="按发票类型编码搜索" class="w-64 px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                        
                        <!-- 搜索按钮 -->
                        <button class="px-3 py-2 bg-gray-100 border border-gray-300 rounded-md hover:bg-gray-200 transition-colors">
                            <i data-lucide="search" class="w-4 h-4"></i>
                        </button>
                        
                        <!-- 刷新按钮 -->
                        <button class="px-3 py-2 bg-gray-100 border border-gray-300 rounded-md hover:bg-gray-200 transition-colors">
                            <i data-lucide="refresh-ccw" class="w-4 h-4"></i>
                        </button>
                        
                        <!-- 高级筛选按钮 -->
                        <button id="advanced-filter-btn" class="px-3 py-2 text-primary hover:bg-secondary rounded-md transition-colors flex items-center">
                            高级筛选
                            <i data-lucide="chevron-down" class="w-4 h-4 ml-1"></i>
                        </button>
                    </div>
                    
                    <!-- 按钮组 -->
                    <div class="flex space-x-3">
                        <button id="add-invoice-type" class="px-4 py-2 bg-primary text-white rounded-md hover:bg-blue-700 transition-colors flex items-center">
                            <i data-lucide="plus" class="w-4 h-4 mr-2"></i>
                            新增发票类型
                        </button>
                    </div>
                </div>
                
                <!-- 高级筛选条件 -->
                <div id="advanced-filter" class="mb-6 grid grid-cols-1 md:grid-cols-3 gap-4 hidden">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">发票类型编码</label>
                        <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">发票类型名称</label>
                        <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">状态</label>
                        <select class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent">
                            <option value="">全部</option>
                            <option value="enabled">启用</option>
                            <option value="disabled">停用</option>
                        </select>
                    </div>
                    <div class="md:col-span-3 flex justify-end space-x-2">
                        <button class="px-4 py-2 bg-white border border-gray-300 rounded-md hover:bg-gray-50 transition-colors">
                            重置
                        </button>
                        <button class="px-4 py-2 bg-primary text-white rounded-md hover:bg-blue-700 transition-colors">
                            查询
                        </button>
                    </div>
                </div>
                
                <!-- 发票类型列表 -->
                <div class="overflow-x-auto">
                    <table class="min-w-full bg-white border border-gray-200 rounded-lg">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">发票类型编码</th>
                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">发票类型名称</th>
                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">说明</th>
                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">状态</th>
                                <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">操作</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            <tr>
                                <td class="px-4 py-2 text-sm text-gray-700">INV001</td>
                                <td class="px-4 py-2 text-sm text-gray-700">增值税专用发票</td>
                                <td class="px-4 py-2 text-sm text-gray-700">可抵扣增值税专用发票</td>
                                <td class="px-4 py-2">
                                    <label class="switch">
                                        <input type="checkbox" checked>
                                        <span class="slider"></span>
                                    </label>
                                </td>
                                <td class="px-4 py-2 text-sm">
                                    <div class="flex space-x-2">
                                        <button class="text-primary hover:text-blue-700 edit-invoice-type">编辑</button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm text-gray-700">INV002</td>
                                <td class="px-4 py-2 text-sm text-gray-700">增值税普通发票</td>
                                <td class="px-4 py-2 text-sm text-gray-700">不可抵扣增值税普通发票</td>
                                <td class="px-4 py-2">
                                    <label class="switch">
                                        <input type="checkbox" checked>
                                        <span class="slider"></span>
                                    </label>
                                </td>
                                <td class="px-4 py-2 text-sm">
                                    <div class="flex space-x-2">
                                        <button class="text-primary hover:text-blue-700 edit-invoice-type">编辑</button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm text-gray-700">INV003</td>
                                <td class="px-4 py-2 text-sm text-gray-700">电子普通发票</td>
                                <td class="px-4 py-2 text-sm text-gray-700">电子形式的增值税普通发票</td>
                                <td class="px-4 py-2">
                                    <label class="switch">
                                        <input type="checkbox" checked>
                                        <span class="slider"></span>
                                    </label>
                                </td>
                                <td class="px-4 py-2 text-sm">
                                    <div class="flex space-x-2">
                                        <button class="text-primary hover:text-blue-700 edit-invoice-type">编辑</button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm text-gray-700">INV004</td>
                                <td class="px-4 py-2 text-sm text-gray-700">机动车销售统一发票</td>
                                <td class="px-4 py-2 text-sm text-gray-700">机动车销售专用发票</td>
                                <td class="px-4 py-2">
                                    <label class="switch">
                                        <input type="checkbox">
                                        <span class="slider"></span>
                                    </label>
                                </td>
                                <td class="px-4 py-2 text-sm">
                                    <div class="flex space-x-2">
                                        <button class="text-primary hover:text-blue-700 edit-invoice-type">编辑</button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td class="px-4 py-2 text-sm text-gray-700">INV005</td>
                                <td class="px-4 py-2 text-sm text-gray-700">定额发票</td>
                                <td class="px-4 py-2 text-sm text-gray-700">固定金额的发票</td>
                                <td class="px-4 py-2">
                                    <label class="switch">
                                        <input type="checkbox" checked>
                                        <span class="slider"></span>
                                    </label>
                                </td>
                                <td class="px-4 py-2 text-sm">
                                    <div class="flex space-x-2">
                                        <button class="text-primary hover:text-blue-700 edit-invoice-type">编辑</button>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                
                <!-- 分页 -->
                <div class="mt-6 flex items-center justify-between">
                    <div class="text-sm text-gray-500">
                        显示 1 至 5 条，共 5 条
                    </div>
                    <div class="flex space-x-1">
                        <button class="px-3 py-1 border border-gray-300 rounded-md text-sm text-gray-500 hover:bg-gray-50 disabled:opacity-50" disabled>
                            上一页
                        </button>
                        <button class="px-3 py-1 border border-primary bg-primary text-white rounded-md text-sm">1</button>
                        <button class="px-3 py-1 border border-gray-300 rounded-md text-sm text-gray-500 hover:bg-gray-50 disabled:opacity-50" disabled>
                            下一页
                        </button>
                    </div>
                </div>
        </main>
    </div>
    
    <!-- 新增/编辑发票类型抽屉 -->
    <div id="invoice-type-drawer" class="drawer fixed top-0 right-0 h-full w-[480px] bg-white shadow-lg z-50 overflow-y-auto">
        <div class="p-6">
            <div class="flex justify-between items-center mb-6">
                <h3 id="drawer-title" class="text-lg font-semibold text-gray-900">新增发票类型</h3>
                <button id="close-drawer" class="text-gray-400 hover:text-gray-600">
                    <i data-lucide="x" class="w-5 h-5"></i>
                </button>
            </div>
            
            <form id="invoice-type-form">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">发票类型编码 <span class="text-red-500">*</span></label>
                        <input type="text" id="invoice-type-code" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#003eb3] focus:border-transparent" required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">发票类型名称 <span class="text-red-500">*</span></label>
                        <input type="text" id="invoice-type-name" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#003eb3] focus:border-transparent" required>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">说明</label>
                        <textarea id="invoice-type-desc" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#003eb3] focus:border-transparent" rows="3"></textarea>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">状态</label>
                        <div class="flex items-center">
                            <label class="switch">
                                <input type="checkbox" id="invoice-type-status" checked>
                                <span class="slider"></span>
                            </label>
                            <span class="ml-2 text-sm text-gray-700" id="status-text">启用</span>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">创建人</label>
                            <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50" disabled>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">创建时间</label>
                            <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50" disabled>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">修改人</label>
                            <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50" disabled>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">修改时间</label>
                            <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md bg-gray-50" disabled>
                        </div>
                    </div>
                </div>
                
                <div class="mt-8 flex justify-end space-x-3">
                    <button type="button" id="cancel-btn" class="btn btn-outline px-4 py-2 rounded-md">取消</button>
                    <button type="submit" class="btn btn-primary px-4 py-2 rounded-md">保存</button>
                </div>
            </form>
        </div>
    </div>
    
    <!-- 抽屉遮罩 -->
    <div id="drawer-overlay" class="drawer-overlay fixed inset-0 bg-black bg-opacity-50 z-40"></div>
    
    <script>
        // 初始化 Lucide 图标
        lucide.createIcons();
        
        // 侧边栏折叠/展开功能
        const toggleSidebar = document.getElementById('toggle-sidebar');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('main-content');
        
        toggleSidebar.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
            if (sidebar.classList.contains('collapsed')) {
                mainContent.classList.remove('ml-64');
                mainContent.classList.add('ml-16');
            } else {
                mainContent.classList.remove('ml-16');
                mainContent.classList.add('ml-64');
            }
        });
        
        // 菜单展开/收拢功能
        const menuHeaders = document.querySelectorAll('.menu-header');
        
        menuHeaders.forEach(header => {
            header.addEventListener('click', () => {
                const menuName = header.getAttribute('data-menu');
                const content = document.getElementById(`${menuName}-content`);
                const icon = header.querySelector('.menu-icon');
                
                // 切换内容显示/隐藏
                content.classList.toggle('hidden');
                
                // 切换图标旋转
                if (content.classList.contains('hidden')) {
                    icon.style.transform = 'rotate(0deg)';
                } else {
                    icon.style.transform = 'rotate(180deg)';
                }
            });
        });
        
        // 高亮当前页面的导航项
        const currentPath = window.location.pathname;
        const sidebarItems = document.querySelectorAll('.sidebar-item');
        
        sidebarItems.forEach(item => {
            const href = item.getAttribute('href');
            if (currentPath.includes(href)) {
                item.classList.add('active');
                item.classList.add('text-primary');
                
                // 展开包含当前页面的菜单
                const menuContent = item.closest('.menu-content');
                if (menuContent) {
                    menuContent.classList.remove('hidden');
                    const menuHeader = menuContent.previousElementSibling;
                    if (menuHeader) {
                        const icon = menuHeader.querySelector('.menu-icon');
                        if (icon) {
                            icon.style.transform = 'rotate(180deg)';
                        }
                    }
                }
            }
        });
        
        // 抽屉功能
        const drawer = document.getElementById('invoice-type-drawer');
        const overlay = document.getElementById('drawer-overlay');
        const addBtn = document.getElementById('add-invoice-type');
        const closeBtn = document.getElementById('close-drawer');
        const cancelBtn = document.getElementById('cancel-btn');
        const statusToggle = document.getElementById('invoice-type-status');
        const statusText = document.getElementById('status-text');
        
        // 打开抽屉
        function openDrawer(title) {
            document.getElementById('drawer-title').textContent = title;
            drawer.classList.add('open');
            overlay.classList.add('open');
        }
        
        // 关闭抽屉
        function closeDrawer() {
            drawer.classList.remove('open');
            overlay.classList.remove('open');
        }
        
        // 新增按钮点击事件
        addBtn.addEventListener('click', function() {
            openDrawer('新增发票类型');
            // 重置表单
            document.getElementById('invoice-type-form').reset();
            document.getElementById('invoice-type-status').checked = true;
            statusText.textContent = '启用';
        });
        
        // 编辑按钮点击事件
        document.querySelectorAll('.edit-invoice-type').forEach(btn => {
            btn.addEventListener('click', function() {
                openDrawer('编辑发票类型');
                // 填充表单数据（模拟）
                document.getElementById('invoice-type-code').value = 'INV001';
                document.getElementById('invoice-type-name').value = '增值税专用发票';
                document.getElementById('invoice-type-desc').value = '可抵扣增值税专用发票';
                document.getElementById('invoice-type-status').checked = true;
                statusText.textContent = '启用';
            });
        });
        
        // 关闭抽屉事件
        closeBtn.addEventListener('click', closeDrawer);
        cancelBtn.addEventListener('click', closeDrawer);
        overlay.addEventListener('click', closeDrawer);
        
        // 状态切换文本更新
        statusToggle.addEventListener('change', function() {
            statusText.textContent = this.checked ? '启用' : '停用';
        });
        
        // 表单提交事件
        document.getElementById('invoice-type-form').addEventListener('submit', function(e) {
            e.preventDefault();
            // 模拟提交
            alert('保存成功！');
            closeDrawer();
        });
        
        // 筛选条件选择器功能
        const filterSelect = document.getElementById('filter-select');
        const filterInput = document.getElementById('filter-input');

        filterSelect.addEventListener('change', function() {
            const selectedValue = this.value;
            
            // 根据选择的筛选条件更新占位符
            if (selectedValue === 'code') {
                filterInput.placeholder = '按发票类型编码搜索';
            } else if (selectedValue === 'name') {
                filterInput.placeholder = '按发票类型名称搜索';
            } else if (selectedValue === 'status') {
                filterInput.placeholder = '按状态搜索';
            }
            
            // 清空输入框
            filterInput.value = '';
        });

        // 高级筛选功能
        const advancedFilterBtn = document.getElementById('advanced-filter-btn');
        const advancedFilter = document.getElementById('advanced-filter');

        advancedFilterBtn.addEventListener('click', function() {
            advancedFilter.classList.toggle('hidden');
            
            // 切换按钮文本和图标
            if (!advancedFilter.classList.contains('hidden')) {
                this.innerHTML = '收起筛选 <i data-lucide="chevron-up" class="w-4 h-4 ml-1"></i>';
            } else {
                this.innerHTML = '高级筛选 <i data-lucide="chevron-down" class="w-4 h-4 ml-1"></i>';
            }
            
            // 重新初始化图标
            lucide.createIcons();
        });
    </script>
</body>
</html>